#!/bin/bash
set -e

help() {
  echo "htotheizzo - a simple script that makes updating/upgrading homebrew or apt, gems, pip packages, and node packages so much easier"
}

dcleanup() {
  if ! command -v docker &>/dev/null; then
    return 0
  fi
  local containers
  mapfile -t containers < <(docker ps --filter status=exited -q 2>/dev/null)
  if [ ${#containers[@]} -gt 0 ]; then
    docker rm "${containers[@]}" 2>/dev/null
  fi
  local images
  mapfile -t images < <(docker images --filter dangling=true -q 2>/dev/null)
  if [ ${#images[@]} -gt 0 ]; then
    docker rmi "${images[@]}" 2>/dev/null
  fi
}

update_linux() {
  apt -y update
  apt -y upgrade
  apt -y autoremove
  apt -y autoclean
  apt -y clean
  rm -rf /var/lib/apt/lists/*
}

update_macos() {
  # Update Homebrew and all packages
  brew update
  brew upgrade
  brew cleanup

  # Update Mac App Store apps
  if command -v mas &>/dev/null; then
    mas upgrade
  fi
}

update() {
  echo "htotheizzo is running the update functions"

  # detect the OS for the update functions
  if [[ "$OSTYPE" == "linux-gnu"* ]]; then
    echo "Hey there Linux user. You rule."

    # on linux, make sure they are the super user
    if [ "$UID" -ne 0 ]; then
      echo "Please run as root"
      exit 1
    fi

    update_linux

  elif [[ "$OSTYPE" == "darwin"* ]]; then
    echo "Hey there macOS user. Updating Homebrew packages..."

    update_macos
  else
    echo "We don't have update functions for OS: ${OSTYPE}"
    echo "Moving on..."
  fi

  # Clean up dangling docker images (works on both platforms via Rancher Desktop)
  dcleanup || true

  echo "htotheizzo is complete, you got 99 problems but updates ain't one"
}

main() {
  local arg=$1
  if [[ ! -z "$arg" ]]; then
    help
  else
    update
  fi
}

main "$@"

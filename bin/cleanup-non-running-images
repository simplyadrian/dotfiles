#!/bin/bash
##############################################################################
# cleanup-non-running-images
# -----------
# Removes all the docker images that are not associated with a running container.
#
# :authors: Jess Frazelle, @jessfraz
# :date: 15 May 2016
# :version: 0.0.1
##############################################################################
set -e
set -o pipefail

main() {
  local all_images
  all_images=$(docker images -q --no-trunc)
  for c in $(docker ps -aq); do
    local image
    image=$(docker inspect --format '{{.Image}}' "$c")
    all_images=$(echo "$all_images" | grep -v "$image" || true)
  done

  if [ -n "$all_images" ]; then
    echo "$all_images" | xargs docker rmi -f 2>&1 || true
  fi
}

main

#!/bin/bash
# Bash wrappers for docker run commands
# Works with Docker CLI provided by Rancher Desktop (dockerd/moby engine)
# Ensure Rancher Desktop is running with the "dockerd (moby)" container engine

# Bail out early if docker is not available
if ! command -v docker &>/dev/null; then
  return 0 2>/dev/null || exit 0
fi

# Auto-negotiate Docker API version when client is newer than server.
# Common on macOS 11 (Big Sur) where the Docker CLI and Colima daemon
# are pinned at different versions due to Homebrew Tier 3 limitations.
if [[ -z "${DOCKER_API_VERSION:-}" ]]; then
  _server_api=$(docker version --format '{{.Server.APIVersion}}' 2>/dev/null || true)
  if [[ -n "$_server_api" ]]; then
    export DOCKER_API_VERSION="$_server_api"
  fi
  unset _server_api
fi

export DOCKER_REPO_PREFIX=jess

#
# Helper Functions
#
dcleanup() {
  local containers
  containers=$(docker ps -aq 2>/dev/null)
  if [ -n "$containers" ]; then
    echo "$containers" | xargs docker rm 2>/dev/null || true
  fi

  local volumes
  volumes=$(docker ps --filter status=exited -q 2>/dev/null)
  if [ -n "$volumes" ]; then
    echo "$volumes" | xargs docker rm -v 2>/dev/null || true
  fi

  local images
  images=$(docker images --filter dangling=true -q 2>/dev/null)
  if [ -n "$images" ]; then
    echo "$images" | xargs docker rmi 2>/dev/null || true
  fi
}
del_stopped() {
  local name=$1
  local state
  state=$(docker inspect --format "{{.State.Running}}" "$name" 2>/dev/null)

  if [[ "$state" == "false" ]]; then
    docker rm "$name"
  fi
}
relies_on() {
  for container in "$@"; do
    local state
    state=$(docker inspect --format "{{.State.Running}}" "$container" 2>/dev/null)

    if [[ "$state" == "false" ]] || [[ "$state" == "" ]]; then
      echo "$container is not running, starting it for you."
      $container
    fi
  done
}

#
# Media Stack (Kubernetes via Rancher Desktop)
#
# The full media stack (plex, sonarr, radarr, transmission, prowlarr, bazarr,
# overseerr, flaresolverr) is managed via Kubernetes manifests.
# Requires: Rancher Desktop with Kubernetes enabled (macOS 12+ / Linux)
# Paths are templated — set CONFIG_PATH, DOWNLOADS_PATH, MEDIA_PATH,
# PLEX_CONFIG_PATH, PLEX_TRANSCODE_PATH in ~/.extra
# See: ~/dotfiles/media/k8s/
#
_media_check_kubectl() {
  if ! command -v kubectl &>/dev/null; then
    echo "ERROR: kubectl not found."
    echo "  The media stack requires Rancher Desktop with Kubernetes enabled."
    echo "  Rancher Desktop requires macOS 12 (Monterey) or later."
    return 1
  fi
}
media_up() {
  _media_check_kubectl || return 1

  local media_dir="${HOME}/dotfiles/media/k8s"
  if [[ ! -d "${media_dir}" ]]; then
    echo "Media stack not found at ${media_dir}"
    return 1
  fi

  # Verify required env vars are set (from ~/.extra)
  local -a required_vars=(CONFIG_PATH DOWNLOADS_PATH MEDIA_PATH PLEX_CONFIG_PATH PLEX_TRANSCODE_PATH)
  local missing=0
  for var in "${required_vars[@]}"; do
    if [[ -z "${!var}" ]]; then
      echo "ERROR: \$${var} is not set. Add it to ~/.extra"
      missing=1
    fi
  done
  if [[ $missing -eq 1 ]]; then
    return 1
  fi

  # Substitute env vars in manifests and apply
  local vars='${CONFIG_PATH} ${DOWNLOADS_PATH} ${MEDIA_PATH} ${PLEX_CONFIG_PATH} ${PLEX_TRANSCODE_PATH}'
  for f in "${media_dir}"/*.yaml; do
    envsubst "$vars" < "$f" | kubectl apply -f -
  done
  echo "Media stack deployed. Run 'media_ps' to check status."
}
media_down() {
  _media_check_kubectl || return 1
  kubectl delete namespace media
}
media_ps() {
  _media_check_kubectl || return 1
  kubectl get pods -n media
}
media_logs() {
  _media_check_kubectl || return 1
  if [[ -z "$1" ]]; then
    echo "Usage: media_logs <service> (e.g. media_logs plex)"
    return 1
  fi
  kubectl logs -n media -l "app=$1" -f
}
media_svc() {
  _media_check_kubectl || return 1
  kubectl get svc -n media
}
media_update() {
  # Pull latest images and rolling-restart all media deployments.
  # Usage: media_update [service ...]
  #   media_update          — update ALL services
  #   media_update sonarr   — update only sonarr
  _media_check_kubectl || return 1

  local -a deployments
  if [[ $# -gt 0 ]]; then
    deployments=("$@")
  else
    mapfile -t deployments < <(kubectl get deployments -n media -o jsonpath='{.items[*].metadata.name}')
  fi

  for dep in "${deployments[@]}"; do
    echo "⟳  Rolling restart: ${dep}"
    kubectl rollout restart deployment/"${dep}" -n media
  done

  echo ""
  echo "Waiting for rollouts to complete..."
  for dep in "${deployments[@]}"; do
    kubectl rollout status deployment/"${dep}" -n media --timeout=120s
  done
  echo "✓ Update complete. Run 'media_ps' to verify."
}
media_restart() {
  # Restart a single service (delete its pod so it gets recreated)
  _media_check_kubectl || return 1
  if [[ -z "$1" ]]; then
    echo "Usage: media_restart <service> (e.g. media_restart sonarr)"
    return 1
  fi
  kubectl delete pod -n media -l "app=$1"
  echo "Pod for $1 deleted — Kubernetes will recreate it."
}
media_shell() {
  # Open a shell inside a running service pod
  _media_check_kubectl || return 1
  if [[ -z "$1" ]]; then
    echo "Usage: media_shell <service> (e.g. media_shell sonarr)"
    return 1
  fi
  local pod
  pod=$(kubectl get pods -n media -l "app=$1" -o jsonpath='{.items[0].metadata.name}' 2>/dev/null)
  if [[ -z "$pod" ]]; then
    echo "No running pod found for app=$1"
    return 1
  fi
  kubectl exec -it -n media "$pod" -- /bin/bash 2>/dev/null || kubectl exec -it -n media "$pod" -- /bin/sh
}
media_images() {
  # Show current image versions for all media pods
  _media_check_kubectl || return 1
  kubectl get pods -n media -o custom-columns='POD:.metadata.name,IMAGE:.spec.containers[*].image,STATUS:.status.phase'
}

#
# Standalone Container Aliases
#
gitsome() {
  docker run --rm -it \
    -v /etc/localtime:/etc/localtime:ro \
    --name gitsome \
    --hostname gitsome \
    -v "${HOME}/.gitsomeconfig:/home/anon/.gitsomeconfig" \
    -v "${HOME}/.gitsomeconfigurl:/home/anon/.gitsomeconfigurl" \
    ${DOCKER_REPO_PREFIX}/gitsome
}
hollywood() {
  docker run --rm -it \
    --name hollywood \
    ${DOCKER_REPO_PREFIX}/hollywood
}
htop() {
  docker run --rm -it \
    --pid host \
    --net none \
    --name htop \
    ${DOCKER_REPO_PREFIX}/htop
}
netcat() {
  docker run --rm -it \
    --net host \
    ${DOCKER_REPO_PREFIX}/netcat "$@"
}
s3cmdocker() {
  del_stopped s3cmd

  docker run --rm -it \
    -e AWS_ACCESS_KEY="${DOCKER_AWS_ACCESS_KEY}" \
    -e AWS_SECRET_KEY="${DOCKER_AWS_ACCESS_SECRET}" \
    -v "$(pwd):/root/s3cmd-workspace" \
    --name s3cmd \
    ${DOCKER_REPO_PREFIX}/s3cmd "$@"
}
telnet() {
  docker run -it --rm \
    --log-driver none \
    ${DOCKER_REPO_PREFIX}/telnet "$@"
}
traceroute() {
  docker run --rm -it \
    --net host \
    ${DOCKER_REPO_PREFIX}/traceroute "$@"
}


#!/bin/bash
# .extra — Personal settings not committed to version control
# Copy this file to ~/.extra and customize
#
# This file is sourced by .bashrc and is gitignored, so it's safe
# to put secrets, personal paths, and host-specific configuration here.

###
### Git credentials
###
GIT_AUTHOR_NAME="Your Name"
GIT_COMMITTER_NAME="$GIT_AUTHOR_NAME"
git config --global user.name "$GIT_AUTHOR_NAME"

GIT_AUTHOR_EMAIL="email@example.com"
GIT_COMMITTER_EMAIL="$GIT_AUTHOR_EMAIL"
git config --global user.email "$GIT_AUTHOR_EMAIL"

GH_USER="yourusername"
git config --global github.user "$GH_USER"

###
### GPG signing key (optional)
###
# git config --global user.signingkey 0xYOURKEYID

###
### Personal aliases
###
# Host-specific aliases that shouldn't be in version control
# alias home="ssh user@your-server.com"
# alias work="ssh user@work-server.com"

###
### Environment variables for media stack
###
# export PLEX_CLAIM="claim-XXXXXXXXXXXX"  # Get from https://plex.tv/claim

###
### AWS credentials for docker containers
###
# export DOCKER_AWS_ACCESS_KEY="AKIAXXXXXXXXXXXXXXXX"
# export DOCKER_AWS_ACCESS_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

###
### Network interface override for packet sniffing
###
# export NETIF="en0"  # Override auto-detection


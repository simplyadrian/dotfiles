# Media Stack — environment variables
# Copy to .env and customise before running `docker compose up -d`

# User / group IDs (run `id` to find yours)
PUID=1000
PGID=1000

# Timezone (see: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/Chicago

# Base path for per-service config directories
# Each service creates a subfolder (e.g. sonarr, radarr, …)
CONFIG_PATH=~/docker/configs

# Plex-specific paths
PLEX_CONFIG_PATH=~/docker/configs/plex
PLEX_TRANSCODE_PATH=/tmp/plex-transcode

# Plex claim token (get one at https://plex.tv/claim)
PLEX_CLAIM=

# Shared media library (movies, TV, music)
MEDIA_PATH=/mnt/media

# Download directory used by Transmission
DOWNLOADS_PATH=~/Torrents

